{
  "name": "necofi",
  "private": true,
  "packageManager": "pnpm@10.6.2",
  "pnpm": {
    "overrides": {
      "react": "18.2.0",
      "react-dom": "18.2.0"
    }
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @necofi/api dev",
    "dev:web": "pnpm --filter @necofi/web dev",
    "build": "turbo run build",
    "check": "pnpm lint && pnpm typecheck && pnpm build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write .",
    "dev:landing": "pnpm --filter @necofi/landing dev",
    "dev:mobile": "pnpm --filter @necofi/mobile dev",
    "prisma:generate": "pnpm --filter @necofi/api prisma:generate",
    "prisma:migrate": "pnpm --filter @necofi/api prisma:migrate",
    "prisma:studio": "pnpm --filter @necofi/api prisma:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
